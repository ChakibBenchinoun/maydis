{
  "name": "maydis",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "website:dev": "pnpm --filter @maydis/website dev",
    "website:build": "pnpm --filter @maydis/website build",
    "website:lint": "pnpm --filter @maydis/website lint",
    "website:lint:fix": "pnpm --filter @maydis/website lint:fix",
    "website:format": "pnpm --filter @maydis/website format",
    "website:format:check": "pnpm --filter @maydis/website format:check",
    "website:format:fix": "pnpm --filter @maydis/website format:fix"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
