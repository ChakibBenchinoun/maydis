# Copy to: apps/website/.env.local
# cp .env.example apps/website/.env.local

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL must be https://….supabase.co (NOT a postgres:// URI)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── WhatsApp (free Baileys bot — see docs/WHATSAPP.md) ──────────────────────
# Owner: 0540580738 → 213540580738
WHATSAPP_OWNER_PHONE=213540580738
WHATSAPP_PROVIDER=baileys

# Local:  pnpm whatsapp:bot  → http://127.0.0.1:3100
# Prod:   https://your-bot.up.railway.app  (or Fly/Render/VPS)
WHATSAPP_BOT_URL=http://127.0.0.1:3100

# Required in production (same value on bot host + Vercel)
# WHATSAPP_BOT_SECRET=generate-a-long-random-string

# Optional free owner-only fallback: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# CALLMEBOT_APIKEY=
