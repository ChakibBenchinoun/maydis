# Copy to apps/website/.env.local (or root .env.local if using turbo filter)

# Public site URL (used for QR codes in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (optional but recommended for reserve inserts)
SUPABASE_SERVICE_ROLE_KEY=
